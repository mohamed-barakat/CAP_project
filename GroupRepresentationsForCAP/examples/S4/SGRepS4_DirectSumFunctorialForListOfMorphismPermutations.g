#! @Chapter Skeletal Category of group represenations
#! @Section Examples and Tests

#! @Example
LoadPackage( "GroupRepresentationsForCAP", false );
#! true

QQ := HomalgFieldOfRationalsInSingular();;
S4 := SymmetricGroup( 4 );;
SGReps := SkeletalCategoryOfGroupRepresentations( S4, QQ : no_precompiled_code := false );;

A := ObjectConstructor( SGReps, [ 2, [1,4], [1,2] ] );;
B := ObjectConstructor( SGReps, [ 2, [2,3], [1,3] ] );;
C := ObjectConstructor( SGReps, [ 3, [2,4,5], [2,3,5] ] );;
ABC := TensorProductOnObjects( TensorProductOnObjects( A, B ), C);;

permutation := SGREPS_Associator_1_Morphism( SGReps, A, B, C, ABC );;
L := [ permutation, permutation ];;
direct_sum := ObjectConstructor( SGReps, NTuple( 3, 5, [1..5], [1..5] ) );;
IsWellDefined( direct_sum );
#! true
sum_permutations := SGREPS_DirectSumFunctorialForListOfMorphismPermutations( SGReps, L, direct_sum );
