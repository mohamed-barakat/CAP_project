#! @Chapter Examples
LoadPackage( "GroupRepresentationsForCAP" );

#! @Example
RepG := RepresentationCategory( SymmetricGroup( 4 ) );;
G := UnderlyingGroupForRepresentationCategory( RepG );;

irr := Irr( G );;

v1 := RepresentationCategoryObject( irr[1], RepG );;
v2 := RepresentationCategoryObject( irr[2], RepG );;
v3 := RepresentationCategoryObject( irr[3], RepG );;
v4 := RepresentationCategoryObject( irr[4], RepG );;
v5 := RepresentationCategoryObject( irr[5], RepG );;

L := [ v1, v2, v3, v4, v5 ];;

A := RepresentationCategoryObject( [ [ 1, irr[1] ], [ 2, irr[4] ] ], RepG );;
B := RepresentationCategoryObject( [ [ 1, irr[2] ], [ 3, irr[3] ] ], RepG );;
C := RepresentationCategoryObject( [ [ 2, irr[2] ], [ 3, irr[4] ], [ 5, irr[5] ] ], RepG );;
ABC := TensorProductOnObjects( TensorProductOnObjects( A, B ), C );;
BAC := TensorProductOnObjects( TensorProductOnObjects( B, A ), C );;
BCBAC := TensorProductOnObjects( TensorProductOnObjects( TensorProductOnObjects( B, C ), TensorProductOnObjects( B, A ) ), C );;

SEMISIMPLECATEGORY_Associator_3_Morphism( A, B, C, ABC );
